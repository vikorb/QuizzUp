{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"],
    "noEmit": true,
    "composite": true
  },
  "include": [
    "backend/src/**/*.ts",
    "tests/backend/**/*.ts",
    "shared/src/**/*.ts",
    "vitest.backend.config.ts"
  ],
  "exclude": [
    "node_modules",
    "frontend",
    "dist",
    "coverage"
  ]
}
