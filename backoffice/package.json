{
  "name": "quizzup_backoffice",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "vitest --run --config vitest.backend.config.ts",
    "test:frontend": "vitest --run --config vitest.frontend.config.ts",
    "test:watch": "concurrently \"npm run test:backend:watch\" \"npm run test:frontend:watch\"",
    "test:backend:watch": "vitest --config vitest.backend.config.ts --watch",
    "test:frontend:watch": "vitest --config vitest.frontend.config.ts --watch",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend",
    "test:coverage:backend": "vitest --run --coverage --config vitest.backend.config.ts",
    "test:coverage:frontend": "vitest --run --coverage --config vitest.frontend.config.ts"
  },
