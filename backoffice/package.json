{
  "name": "quizzup-backoffice",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Backoffice administration for QuizzUp",
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "vitest --run --config vitest.backend.config.ts",
    "test:frontend": "vitest --run --config vitest.frontend.config.ts",
    "test:watch": "concurrently \"npm run test:backend:watch\" \"npm run test:frontend:watch\"",
    "test:backend:watch": "vitest --config vitest.backend.config.ts --watch",
    "test:frontend:watch": "vitest --config vitest.frontend.config.ts --watch",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend",
    "test:coverage:backend": "vitest --run --coverage --config vitest.backend.config.ts",
    "test:coverage:frontend": "vitest --run --coverage --config vitest.frontend.config.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/test-utils": "^2.4.10",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.8.0",
    "fastify": "^5.7.4",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "vue-eslint-parser": "^10.4.0"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
